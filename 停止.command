#!/bin/bash
# ============================================================
#  停止「中城交智枢」本地开发环境（前端 + 后端）
#  用法：双击本文件即可全部停掉。
# ============================================================
echo "正在停止中城交智枢 前后端 ..."
pkill -f "uvicorn app.gateway" 2>/dev/null
pkill -f "next dev" 2>/dev/null
sleep 1
echo "✅ 已停止。可以关闭本窗口。"

# ─────────────────────────────────────────────────────────────────────
# MinerU OCR 配置（供 post-evaluation 处理扫描件 PDF / Word 等非文本 PDF）
#
# ⚠️ 这些变量由 MainAgent 平台从它**部署目录的 .env** 读取——技能仓库本身
#    不读 env（skills 加载器只认 SKILL.md/scripts/references/templates）。
#    所以：把下面两行复制到 MainAgent 部署的 .env 并填入真实 key，MinerU 才会生效；
#    写在技能仓库里不会被平台读取。真实密钥只放部署 .env，切勿提交进任何仓库。
#
# 配套（改 MainAgent 部署的 config.yaml，见 README-集成说明.md）：
#   knowledge:
#     enabled: true
#     backend: vlm-http-client
#     server_url: http://220.248.124.138:13889   # MinerU VLM 服务地址
#     api_key: $MINERU_API_KEY                    # 只放引用，明文 key 进 .env
#     language: ch
#
# 依赖：uv pip install mineru==3.1.5
# ─────────────────────────────────────────────────────────────────────

MINERU_API_KEY=
MINERU_VL_API_KEY=
